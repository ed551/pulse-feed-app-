{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "role": { "type": "string", "description": "The user's role (e.g., admin, user)" },
        "twoFactorEnabled": { "type": "boolean", "description": "Whether 2FA is enabled" },
        "twoFactorType": { "type": "string", "enum": ["biometric", "email_otp", "sms_otp"], "description": "The type of 2FA" },
        "phoneNumber": { "type": "string", "description": "The user's phone number for SMS OTP" },
        "theme": { "type": "string", "enum": ["light", "dark", "system"], "description": "User's theme preference" },
        "blockedUsers": { "type": "array", "items": { "type": "string" }, "description": "List of blocked user UIDs" },
        "blockedGroups": { "type": "array", "items": { "type": "string" }, "description": "List of blocked group IDs" },
        "contentFilters": { 
          "type": "object", 
          "properties": {
            "sensitiveContent": { "type": "boolean" },
            "spamFilter": { "type": "boolean" },
            "directMessagePrivacy": { "type": "string", "enum": ["everyone", "following", "none"] }
          }
        },
        "points": { "type": "number", "description": "The user's reward points" },
        "balance": { "type": "number", "description": "The user's wallet balance" },
        "membershipLevel": { "type": "string", "enum": ["bronze", "silver", "gold"], "description": "The user's current membership tier" },
        "membershipStatus": { "type": "string", "enum": ["active", "expired", "pending"], "description": "The status of the user's membership" },
        "adRevenue": { "type": "number", "description": "The user's total ad revenue generated" },
        "educationRevenue": { "type": "number", "description": "The user's total education revenue generated" },
        "activeTimeRevenue": { "type": "number", "description": "The user's revenue from active engagement" },
        "datingRevenue": { "type": "number", "description": "The user's revenue from dating features" },
        "communityRevenue": { "type": "number", "description": "The user's revenue from community participation" },
        "eventsRevenue": { "type": "number", "description": "The user's revenue from event participation" },
        "bio": { "type": "string", "description": "The user's bio" },
        "badges": { "type": "array", "items": { "$ref": "#/entities/Badge" }, "description": "The user's earned badges" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Badge": {
      "title": "Badge",
      "description": "An educational badge earned by a user",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the badge" },
        "date": { "type": "string", "format": "date-time", "description": "When the badge was earned" },
        "type": { "type": "string", "description": "The type of badge (e.g., LinkedIn-Style)" },
        "icon": { "type": "string", "description": "The icon name for the badge" },
        "description": { "type": "string", "description": "A description of why the badge was awarded" }
      },
      "required": ["name", "date", "type", "icon", "description"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction for a user",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "The amount of the transaction" },
        "phoneNumber": { "type": "string", "description": "The phone number or email associated with the transaction" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"], "description": "The status of the transaction" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred" },
        "reference": { "type": "string", "description": "The transaction reference" },
        "type": { "type": "string", "enum": ["mpesa", "international"], "description": "The type of transaction" },
        "method": { "type": "string", "description": "The payout method (e.g., paypal, stripe, bank)" },
        "revenueSource": { "type": "string", "enum": ["ad", "education"], "description": "The source of the revenue" }
      },
      "required": ["amount", "status", "timestamp", "reference", "type", "revenueSource"]
    },
    "Post": {
      "title": "Post",
      "description": "A post created by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The post's unique ID" },
        "authorId": { "type": "string", "description": "The ID of the user who created the post" },
        "author": { "type": "string", "description": "The name of the user who created the post" },
        "avatar": { "type": "string", "description": "The avatar of the user who created the post" },
        "title": { "type": "string", "description": "The title of the post" },
        "content": { "type": "string", "description": "The content of the post" },
        "type": { "type": "string", "enum": ["post", "announcement", "update", "video", "live", "poll"], "description": "The type of post" },
        "category": { "type": "string", "description": "The category of the post" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "The tags associated with the post" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "The images associated with the post" },
        "gifUrl": { "type": "string", "description": "The URL of a GIF associated with the post" },
        "videoUrl": { "type": "string", "description": "The URL of a video associated with the post" },
        "poll": { 
          "type": "object", 
          "properties": {
            "question": { "type": "string" },
            "options": { 
              "type": "array", 
              "items": { 
                "type": "object",
                "properties": {
                  "text": { "type": "string" },
                  "votes": { "type": "number" },
                  "voters": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "likes": { "type": "number", "description": "The number of likes the post has received" },
        "reactions": { "type": "object", "description": "Emoji reactions for the post" },
        "comments": { "type": "number", "description": "The number of comments the post has received" },
        "shares": { "type": "number", "description": "The number of shares the post has received" },
        "reports": { "type": "number", "description": "The number of times the post has been reported" },
        "time": { "type": "string", "format": "date-time", "description": "When the post was created" },
        "isLiked": { "type": "boolean", "description": "Whether the current user has liked the post" },
        "commentsList": { "type": "array", "items": { "$ref": "#/entities/PostComment" }, "description": "The comments on the post" },
        "analytics": { "type": "array", "items": { "$ref": "#/entities/PostAnalytics" }, "description": "The analytics for the post" }
      },
      "required": ["id", "authorId", "author", "title", "content", "category", "time", "type"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The comment's unique ID" },
        "authorId": { "type": "string", "description": "The ID of the user who created the comment" },
        "author": { "type": "string", "description": "The name of the user who created the comment" },
        "avatar": { "type": "string", "description": "The avatar of the user who created the comment" },
        "content": { "type": "string", "description": "The content of the comment" },
        "likes": { "type": "number", "description": "The number of likes the comment has received" },
        "isLiked": { "type": "boolean", "description": "Whether the current user has liked the comment" },
        "time": { "type": "string", "format": "date-time", "description": "When the comment was created" },
        "replies": { "type": "array", "items": { "$ref": "#/entities/PostComment" }, "description": "The replies to the comment" }
      },
      "required": ["id", "authorId", "author", "content", "time"]
    },
    "PostAnalytics": {
      "title": "PostAnalytics",
      "description": "Analytics for a post",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the metric" },
        "views": { "type": "number", "description": "The number of views" },
        "likes": { "type": "number", "description": "The number of likes" },
        "shares": { "type": "number", "description": "The number of shares" },
        "comments": { "type": "number", "description": "The number of comments" }
      },
      "required": ["name", "views", "likes", "shares", "comments"]
    },
    "Insight": {
      "title": "Insight",
      "description": "AI-generated insight for app improvement or user coaching",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["developer", "user"], "description": "Who the insight is for" },
        "category": { "type": "string", "description": "The category of the insight (e.g., UI, Performance, Health, Life)" },
        "content": { "type": "string", "description": "The content of the insight" },
        "authorId": { "type": "string", "description": "The ID of the user who triggered the insight" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the insight was generated" }
      },
      "required": ["type", "category", "content", "authorId", "timestamp"]
    },
    "Event": {
      "title": "Event",
      "description": "An event organized by a user or the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The event's unique ID" },
        "title": { "type": "string", "description": "The title of the event" },
        "description": { "type": "string", "description": "The description of the event" },
        "date": { "type": "string", "format": "date-time", "description": "The date and time of the event" },
        "location": { "type": "string", "description": "The location of the event" },
        "organizerId": { "type": "string", "description": "The ID of the user organizing the event" },
        "attendees": { "type": "array", "items": { "type": "string" }, "description": "The IDs of users attending the event" },
        "category": { "type": "string", "description": "The category of the event" },
        "imageUrl": { "type": "string", "description": "The URL of the event image" }
      },
      "required": ["id", "title", "description", "date", "location", "organizerId", "category"]
    },
    "CommunityReport": {
      "title": "CommunityReport",
      "description": "A report of a local community issue",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The report's unique ID" },
        "title": { "type": "string", "description": "The title of the report" },
        "description": { "type": "string", "description": "The description of the problem" },
        "category": { "type": "string", "description": "The category of the problem (e.g., Safety, Infrastructure)" },
        "status": { "type": "string", "enum": ["Pending", "Investigating", "Resolved"], "description": "The current status of the report" },
        "location": { "type": "string", "description": "The location of the problem" },
        "reporterName": { "type": "string", "description": "The name of the user who reported the issue" },
        "reporterUid": { "type": "string", "description": "The UID of the user who reported the issue" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was submitted" },
        "upvotes": { "type": "number", "description": "The number of upvotes the report has received" },
        "aiAnalysis": { "type": "string", "description": "AI-generated assessment of the report" }
      },
      "required": ["title", "description", "location", "reporterName", "reporterUid", "timestamp", "status"]
    },
    "CommunityPoll": {
      "title": "CommunityPoll",
      "description": "A community-wide poll for governance or feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The poll's unique ID" },
        "question": { "type": "string", "description": "The question being asked" },
        "options": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "votes": { "type": "number" }
            }
          }
        },
        "voters": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users who voted" },
        "endsAt": { "type": "string", "format": "date-time", "description": "When the poll ends" },
        "category": { "type": "string", "description": "The category of the poll" },
        "status": { "type": "string", "enum": ["Active", "Closed"] }
      },
      "required": ["question", "options", "endsAt", "category", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation between users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The chat's unique ID" },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "The UIDs of the users in the chat" },
        "lastMessage": { "type": "string", "description": "The content of the last message" },
        "lastMessageTime": { "type": "string", "format": "date-time", "description": "When the last message was sent" },
        "unreadCount": { "type": "number", "description": "The number of unread messages" },
        "lastSenderId": { "type": "string", "description": "The UID of the last message sender" }
      },
      "required": ["participants"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The message's unique ID" },
        "senderId": { "type": "string", "description": "The UID of the user who sent the message" },
        "text": { "type": "string", "description": "The content of the message" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"], "description": "The status of the message" }
      },
      "required": ["senderId", "text", "timestamp", "status"]
    },
    "UserPublic": {
      "title": "UserPublic",
      "description": "Publicly accessible user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "PlatformStats": {
      "title": "PlatformStats",
      "description": "Global platform financial and engagement statistics",
      "type": "object",
      "properties": {
        "platformRevenue": { "type": "number", "description": "Total revenue generated by the platform" },
        "developerShare": { "type": "number", "description": "Current withdrawable share for the developer" },
        "totalUsers": { "type": "number", "description": "Total number of registered users" },
        "totalPosts": { "type": "number", "description": "Total number of posts created" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "When the stats were last updated" }
      },
      "required": ["platformRevenue", "developerShare", "lastUpdated"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "#/entities/User",
      "description": "Stores user profiles"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "#/entities/Transaction",
      "description": "Stores user transactions"
    },
    "posts/{postId}": {
      "schema": "#/entities/Post",
      "description": "Stores posts"
    },
    "insights/{insightId}": {
      "schema": "#/entities/Insight",
      "description": "Stores AI-generated insights and feedback"
    },
    "events/{eventId}": {
      "schema": "#/entities/Event",
      "description": "Stores events"
    },
    "community_reports/{reportId}": {
      "schema": "#/entities/CommunityReport",
      "description": "Stores community problem reports"
    },
    "community_polls/{pollId}": {
      "schema": "#/entities/CommunityPoll",
      "description": "Stores community-wide polls"
    },
    "chats/{chatId}": {
      "schema": "#/entities/Chat",
      "description": "Stores chat conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "#/entities/ChatMessage",
      "description": "Stores messages within a chat"
    },
    "users_public/{userId}": {
      "schema": "#/entities/UserPublic",
      "description": "Stores public user profiles"
    },
    "platform/stats": {
      "schema": "#/entities/PlatformStats",
      "description": "Stores global platform statistics"
    }
  }
}
